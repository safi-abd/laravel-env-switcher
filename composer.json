{
    "name": "mohammadsafiabdullah/laravel-env-switcher",
    "description": "Safely switch Laravel asset folders between local (public/) and shared-hosting (root) layouts.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "shared-hosting", "assets", "deployment", "environment"],
    "authors": [
        {
            "name": "M Safi Abdullah",
            "email": "saficodes@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "MohammadSafiAbdullah\\EnvSwitcher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MohammadSafiAbdullah\\EnvSwitcher\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MohammadSafiAbdullah\\EnvSwitcher\\EnvSwitcherServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}